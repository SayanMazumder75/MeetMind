# AI Meeting Notes — Environment Configuration
# Copy this file to .env and fill in your values

# ─── Speech Recognition ───────────────────────────────────────────────────────
# assemblyai = cloud (recommended — supports Hindi & Bengali natively)
# whisper    = local (slow, poor Hindi/Bengali support)
SPEECH_ENGINE=assemblyai

# Your AssemblyAI API key (get free key at https://www.assemblyai.com)
ASSEMBLYAI_API_KEY=your_assemblyai_key_here

# Meeting language:
#   hi = Hindi    bn = Bengali    en = English
#   ta = Tamil    te = Telugu     auto = auto-detect
LANGUAGE_CODE=hi

# Translate Hindi/Bengali transcript to English automatically?
TRANSLATE_TO_ENGLISH=true

# Detect who is speaking? (uses AssemblyAI speaker diarization)
SPEAKER_DIARIZATION=true

# ─── Summarization ────────────────────────────────────────────────────────────
# claude       = Claude API (recommended — no download, handles Hindi/Bengali)
# simple       = basic extractive (no API key needed, low quality)
SUMMARIZER=claude

# Anthropic API key (get at https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── Audio Settings ───────────────────────────────────────────────────────────
AUDIO_SAMPLE_RATE=16000

# How many seconds to buffer before sending to API (8s = good balance)
AUDIO_CHUNK_SECONDS=8

# Audio device index (-1 = auto-detect)
# Run "python main.py devices" to list available devices
AUDIO_DEVICE_INDEX=-1

# ─── Export ───────────────────────────────────────────────────────────────────
GOOGLE_CREDENTIALS_PATH=credentials.json

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=AI Meeting Notes
DATA_DIR=data
LOG_LEVEL=INFO
