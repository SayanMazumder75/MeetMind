# AI Meeting Notes - Environment Configuration
# Copy this file to .env and fill in your values

# ─── Speech Recognition ───────────────────────────────────────────────────────
# Choose: "whisper" (local/free), "assemblyai" (cloud), "google" (cloud)
SPEECH_ENGINE=whisper

# Whisper model size: tiny, base, small, medium, large
# Larger = more accurate but slower. "base" is a good starting point.
WHISPER_MODEL=base

# AssemblyAI API key (only needed if SPEECH_ENGINE=assemblyai)
ASSEMBLYAI_API_KEY=your_assemblyai_key_here

# ─── NLP Summarization ────────────────────────────────────────────────────────
# Choose: "transformers" (local HuggingFace), "openai" (GPT), "claude"
SUMMARIZER=transformers

# HuggingFace model for summarization (used when SUMMARIZER=transformers)
SUMMARIZER_MODEL=facebook/bart-large-cnn

# OpenAI API key (only needed if SUMMARIZER=openai)
OPENAI_API_KEY=your_openai_key_here

# Anthropic API key (only needed if SUMMARIZER=claude)
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── Audio Settings ───────────────────────────────────────────────────────────
# Sample rate in Hz (16000 recommended for speech)
AUDIO_SAMPLE_RATE=16000

# Chunk duration in seconds for streaming transcription
AUDIO_CHUNK_SECONDS=5

# Audio device index (-1 = auto-detect, or use list_audio_devices.py to find yours)
AUDIO_DEVICE_INDEX=-1

# ─── Google Docs Export ───────────────────────────────────────────────────────
# Path to your Google service account JSON key file
GOOGLE_CREDENTIALS_PATH=credentials.json

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_NAME=AI Meeting Notes
DATA_DIR=data
LOG_LEVEL=INFO

SPEECH_ENGINE=assemblyai
ASSEMBLYAI_API_KEY=881ed5efcec64703837bd6b745fdd8c2
SPEAKER_DIARIZATION=assemblyai

